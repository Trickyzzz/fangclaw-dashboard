# Server/runtime
NODE_ENV=development
PORT=3000
JWT_SECRET=replace-with-a-secure-random-string
DATABASE_URL=mysql://user:password@127.0.0.1:3306/fangclaw
# or local SQLite-style demo mode (currently DB functions are MySQL-oriented):
# DATABASE_URL=sqlite:./data/fangclaw.db
OAUTH_SERVER_URL=https://your-oauth-server.example.com
OWNER_OPEN_ID=your-owner-open-id

# Built-in service integrations
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com/
BUILT_IN_FORGE_API_KEY=your-forge-api-key
BUILT_IN_FORGE_MODEL_MINI=gpt-5.4-mini
BUILT_IN_FORGE_MODEL_PRO=gpt-5.4
BUILT_IN_FORGE_MODEL_ROUTING_ENABLED=true
BUILT_IN_FORGE_MODEL_PRO_MIN_CHARS=380
BUILT_IN_FORGE_MODEL_PRO_MIN_LINES=8
# Compatibility aliases (either set BUILT_IN_FORGE_* above OR these)
OPENAI_BASE_URL=
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=deepseekv3.2
OPENAI_MODEL_MINI=gpt-5.4-mini
OPENAI_MODEL_PRO=gpt-5.4
OPENAI_MODEL_ROUTING_ENABLED=true
OPENAI_MODEL_PRO_MIN_CHARS=380
OPENAI_MODEL_PRO_MIN_LINES=8

# Frontend/runtime
VITE_APP_ID=your-app-id

# Optional analytics for client/index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
