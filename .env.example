# Server/runtime
NODE_ENV=development
PORT=3000
JWT_SECRET=replace-with-a-secure-random-string
DATABASE_URL=mysql://user:password@127.0.0.1:3306/fangclaw
OAUTH_SERVER_URL=https://your-oauth-server.example.com
OWNER_OPEN_ID=your-owner-open-id

# Built-in service integrations
BUILT_IN_FORGE_API_URL=https://your-forge-api.example.com/
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# Frontend/runtime
VITE_APP_ID=your-app-id

# Optional analytics for client/index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
